DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=
DB_NAME=voting_system
PORT=3000

# Required before production deploys. In development the app falls back to
# an insecure temporary secret and logs a warning.
SESSION_SECRET=replace-with-a-long-random-secret

# Admin dashboard credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Cookie / proxy settings
NODE_ENV=development
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax
TRUST_PROXY=false

# Generate with: node scratch/generate_ballot_keys.js
BALLOT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nreplace-me\n-----END PUBLIC KEY-----"
BALLOT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----"
